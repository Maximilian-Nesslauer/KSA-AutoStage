<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PlatformTarget>x64</PlatformTarget>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Lib.Harmony" Version="2.4.2" />
    <PackageReference Include="StarMap.API" Version="0.3.6" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="KSA">
      <HintPath>..\..\..\refs\game\KSA.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Brutal.Core.Numerics">
      <HintPath>..\..\..\refs\game\Brutal.Core.Numerics.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Brutal.Core.Logging">
      <HintPath>..\..\..\refs\game\Brutal.Core.Logging.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <PatchFile Include="Patches\*.xml" />
  </ItemGroup>

  <ItemGroup>
    <None Update="mod.toml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <Target Name="CopyToMods" AfterTargets="Build">
    <PropertyGroup>
      <ModDir>$(USERPROFILE)\Documents\My Games\Kitten Space Agency\mods\AutoStage\</ModDir>
    </PropertyGroup>
    <MakeDir Directories="$(ModDir)Patches\" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(ModDir)" />
    <Copy SourceFiles="mod.toml" DestinationFolder="$(ModDir)" />
    <Copy SourceFiles="@(PatchFile)" DestinationFolder="$(ModDir)Patches\" />
  </Target>

  <Target Name="PackageRelease" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <PropertyGroup>
      <ReleaseDir>$(OutputPath)release\$(AssemblyName)\</ReleaseDir>
      <ZipPath>$(OutputPath)$(AssemblyName).zip</ZipPath>
    </PropertyGroup>
    <RemoveDir Directories="$(OutputPath)release" />
    <MakeDir Directories="$(ReleaseDir)Patches\" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(ReleaseDir)" />
    <Copy SourceFiles="mod.toml" DestinationFolder="$(ReleaseDir)" />
    <Copy SourceFiles="@(PatchFile)" DestinationFolder="$(ReleaseDir)Patches\" />
    <ZipDirectory SourceDirectory="$(OutputPath)release" DestinationFile="$(ZipPath)" Overwrite="true" />
    <RemoveDir Directories="$(OutputPath)release" />
    <Message Importance="high" Text="Release packaged: $(ZipPath)" />
  </Target>

</Project>
